# Copy to .env. Fill the empty secret values before exposing the service.

# Local runtime defaults. Docker Compose overrides DB_URL with PostgreSQL.
OPENOYSTER_DB_URL=sqlite:///./workspace/openoyster.db
OPENOYSTER_WORKSPACE=./workspace
OPENOYSTER_INBOX_DIR=./workspace/inbox
OPENOYSTER_ARCHIVE_DIR=./workspace/archive

# Required for API mutation endpoints. Read endpoints stay available without it.
# Generate a long random value locally.
OPENOYSTER_API_KEY=
OPENOYSTER_API_ALLOW_UNSAFE_NO_KEY=false
OPENOYSTER_API_KEY_HEADER=X-OpenOyster-Key

# Compose PostgreSQL secret.
# Generate a different long random value locally.
OPENOYSTER_POSTGRES_PASSWORD=

# Extraction provider: local or openai-compatible.
OPENOYSTER_LLM_PROVIDER=local
OPENOYSTER_LLM_API_KEY=
OPENOYSTER_LLM_BASE_URL=https://api.openai.com/v1
OPENOYSTER_LLM_MODEL=gpt-4.1-mini
OPENOYSTER_LLM_TIMEOUT_SECONDS=45
OPENOYSTER_LLM_MAX_RETRIES=2
OPENOYSTER_LLM_FALLBACK_TO_LOCAL=true

OPENOYSTER_LOG_LEVEL=INFO
OPENOYSTER_LOG_JSON=false
OPENOYSTER_MAX_EVENTS_PER_LOOP=100
OPENOYSTER_LOOP_LEASE_SECONDS=300
OPENOYSTER_SCHEDULER_TICK_SECONDS=30
OPENOYSTER_ARCHIVE_PROCESSED_FILES=false
